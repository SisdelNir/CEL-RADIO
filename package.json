{
  "name": "cel-radio-server",
  "version": "2.0.0",
  "description": "Servidor backend para CEL-RADIO (WebRTC SFU + WebSockets + SQLite)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:client": "npx esbuild js/_mediasoup-entry.js --bundle --outfile=js/mediasoup-client.bundle.js --format=iife --global-name=mediasoupClient --minify"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "mediasoup": "^3.14.14",
    "mediasoup-client": "^3.7.17",
    "socket.io": "^4.7.5",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
