# ═══════════════════════════════════════════════════
# CEL-RADIO — Variables de Entorno
# ═══════════════════════════════════════════════════

# Puerto del servidor (default: 3000)
PORT=3000

# Directorio para la base de datos SQLite
DATA_DIR=./data

# ═══ Mediasoup (SFU Media Server) ═══
# IP de escucha (0.0.0.0 para aceptar todas las interfaces)
MEDIASOUP_LISTEN_IP=0.0.0.0
# IP pública del servidor (IMPORTANTE: poner la IP real del VPS en producción)
MEDIASOUP_ANNOUNCED_IP=

# ═══ TURN Server (Coturn o servicio externo) ═══
# Sin TURN, usuarios en redes móviles podrían no conectar
# Formato: turn:IP_O_DOMINIO:PUERTO
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=
